# MTIS API Environment Variables
# Copy to .env and fill in values

# ─── REQUIRED ─────────────────────────────────
JWT_SECRET=
TOTP_ENCRYPTION_KEY=

# ─── OPTIONAL ─────────────────────────────────
NODE_ENV=production
PORT=3000
DB_PATH=/app/data/database.sqlite

# ─── SMTP (omit to disable email sending) ─────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@mtis.vn

# ─── Backups ──────────────────────────────────
BACKUP_DIR=/app/data/backups
BACKUP_KEEP=28

# ─── E2E Testing ──────────────────────────────
ENABLE_E2E_TEST_HOOKS=false
APP_URL=http://localhost:3000
